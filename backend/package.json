{
  "name": "datahex-backend",
  "version": "1.0.0",
  "description": "Backend for Data Science Copilot - Mastra + Node.js + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npx ts-node src/mastra/testing/testRunner.ts",
    "test:all": "npx ts-node src/mastra/testing/testAllAgents.ts",
    "test:orchestrator": "npx ts-node src/mastra/testing/testOrchestrator.ts",
    "test:individual": "npx ts-node src/mastra/testing/testIndividualAgents.ts",
    "test:integration": "npx ts-node src/mastra/testing/testAgentIntegration.ts",
    "test:focus": "npx ts-node src/mastra/testing/testRunner.ts focus",
    "test:suite": "npx ts-node src/mastra/testing/testRunner.ts suite"
  },
  "keywords": [
    "data-science",
    "mastra",
    "ai-agents",
    "cedar-os"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mastra/core": "^0.18.0",
    "@types/multer": "^2.0.0",
    "@types/sqlite3": "^3.1.11",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "duckdb": "^1.4.0",
    "express": "^4.18.2",
    "form-data": "^4.0.4",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "openai": "^5.23.1",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.2"
  }
}
